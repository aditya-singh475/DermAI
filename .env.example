# DermAI — Environment Configuration
# Copy this file to .env and fill in values

# SECURITY: Secret key for JWT tokens (generate a strong random key for production)
SECRET_KEY=change-me-to-a-random-string

# Database path (default: backend/users.db)
# DATABASE_URL=./backend/users.db

# ML Model paths (default: model/models/)
# MODEL_PATH=./model/models/skin_model.h5
# CLASS_MAP_PATH=./model/models/class_indices.json

# Local image upload directory
# UPLOAD_DIR=./backend/uploads

# CORS origins (comma-separated, use specific domains in production)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment
ENVIRONMENT=development
